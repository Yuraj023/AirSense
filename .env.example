# AirSense Dashboard - Environment Variables
# Copy this file to .env.local and fill in your actual credentials

# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Adafruit IO Configuration
VITE_ADAFRUIT_USERNAME=your-adafruit-username
VITE_ADAFRUIT_API_KEY=your-adafruit-api-key
VITE_ADAFRUIT_BASE_URL=https://io.adafruit.com/api/v2

# Brevo Email API Configuration
VITE_BREVO_API_KEY=your-brevo-api-key
VITE_BREVO_API_URL=https://api.brevo.com/v3/smtp/email
VITE_BREVO_SENDER_EMAIL=your-sender-email@example.com
VITE_BREVO_SENDER_NAME=AirSense Monitor
